name: SonarQube Scan

# When does this workflow run?
on:
  push:
    branches:
      - main          # Runs when you push to main branch
  pull_request:
    branches:
      - main          # Runs when someone opens a PR to main

jobs:
  sonarqube-scan:
    name: Run SonarQube Analysis
    runs-on: ubuntu-latest   # GitHub gives us a fresh Linux machine

    steps:

      # Step 1: Download your code onto the runner machine
      - name: Checkout Code
        uses: actions/checkout@v4
        with:
          fetch-depth: 0   # Gets full git history (SonarQube needs this for blame info)

      # Step 2: Run the actual SonarQube scan
      - name: SonarQube Scan
        uses: SonarSource/sonarqube-scan-action@master
        env:
          SONAR_TOKEN: ${{ secrets.SONAR_TOKEN }}         # Reads from GitHub Secret
          SONAR_HOST_URL: ${{ secrets.SONAR_HOST_URL }}   # Reads from GitHub Secret

      # Step 3 (Optional): Fail the workflow if quality gate fails
      - name: SonarQube Quality Gate Check
        uses: SonarSource/sonarqube-quality-gate-action@master
        timeout-minutes: 5
        env:
          SONAR_TOKEN: ${{ secrets.SONAR_TOKEN }}
